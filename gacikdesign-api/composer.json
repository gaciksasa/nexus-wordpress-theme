{
    "name": "gacikdesign/license-api",
    "description": "GacikDesign multi-theme licensing platform",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=8.1",
        "slim/slim": "^4.14",
        "slim/psr7": "^1.7",
        "php-di/php-di": "^7.0",
        "php-di/slim-bridge": "^3.4",
        "monolog/monolog": "^3.7",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "GacikDesign\\Api\\": "src/"
        }
    },
    "scripts": {
        "start": "php -S localhost:8080 -t public",
        "migrate": "php database/migrate.php",
        "seed": "php database/seeds/seed_initial.php"
    }
}
