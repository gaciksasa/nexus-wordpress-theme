# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=gacikdesign_api
DB_USER=root
DB_PASS=

# Envato API
ENVATO_PERSONAL_TOKEN=your_envato_personal_token_here

# HMAC Secret (used to generate site_tokens)
APP_SECRET=generate_a_random_64_char_hex_string_here

# Admin API Key (bcrypt hash stored in DB, raw key used in requests)
# Generate with: php -r "echo bin2hex(random_bytes(32));"

# Environment
APP_ENV=production
APP_DEBUG=false

# Rate Limiting
RATE_LIMIT_ACTIVATE=10
RATE_LIMIT_VERIFY=60
RATE_LIMIT_DOWNLOAD=20
